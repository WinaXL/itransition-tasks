  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/seedrandom": "^3.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
