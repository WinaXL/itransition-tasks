# PostgreSQL connection string (Render / Neon / local)
# For Render, append ?sslmode=require to the External Database URL
DATABASE_URL=postgresql://user:password@host:5432/cvdb?sslmode=require

# Secret for signing session JWTs
JWT_SECRET=change-me

# Where the SPA lives (used for OAuth redirects back to the app)
APP_URL=http://localhost:5173
# Where this API is reachable (used for OAuth callback URLs)
API_URL=http://localhost:3000

# Google OAuth — authorized redirect URI must be exactly:
#   {API_URL}/api/auth/google/callback
# e.g. https://cv-management-tdgj.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — Authorization callback URL must be exactly:
#   {API_URL}/api/auth/github/callback
# e.g. https://cv-management-tdgj.onrender.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
